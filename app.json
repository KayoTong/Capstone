{
  "expo": { // https://docs.expo.dev/workflow/configuration/
    "name": "BeforeIGo", // The name of your app as it appears on the home screen and in the app store.
    "slug": "beforeigo", 
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/beforeigo-ios-icon-1024.png", // The icon for your app, which is used on the home screen and in the app store.
    "scheme": "beforeigo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kayotonge.beforeigo",
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"],
        "NSLocationWhenInUseUsageDescription": "BeforeIGo needs your location to set your home safety zone.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "BeforeIGo needs background location to alert you if you leave home without your essentials.",
        "NSLocationAlwaysUsageDescription": "BeforeIGo needs background location to protect your items even when the app is closed."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/beforeigo-android-adaptive-foreground-1024.png" // The foreground image for the adaptive icon, which is used on Android devices.
      },
     
      "predictiveBackGestureEnabled": false,
      "package": "com.kayotonge.beforeigo",
     
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBC4cfV8vdM3kOdqon_XJnWLCG1WXbBkQg"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf19553a-def2-4c99-bca4-1b40b1cc8c32"
      }
    }
  }
}
